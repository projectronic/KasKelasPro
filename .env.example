# Copy this file to .env.local and fill in your own Supabase project credentials.
# Get these from: Supabase Dashboard > Project Settings > API

# Safe to expose to the browser (protected by Row Level Security).
# Newer Supabase dashboards call this the "Publishable key" (sb_publishable_...)
# instead of "anon public key" — same thing, just a newer name/format.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-or-publishable-key

# Server-side only. NEVER prefix with NEXT_PUBLIC_, NEVER commit, NEVER share.
# Newer dashboards call this the "Secret key" (sb_secret_...) instead of
# "service_role key". Only needed for server-side admin actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-or-secret-key
