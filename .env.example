# Copy this file to .env.local and fill in your own Supabase project credentials.
# Get these from: Supabase Dashboard > Project Settings > API

# Safe to expose to the browser (public/anon key, protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only. NEVER prefix with NEXT_PUBLIC_, NEVER commit, NEVER share.
# Only needed for server-side admin actions (e.g. inviting users, seeding data).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
